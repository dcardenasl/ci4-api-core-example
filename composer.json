{
    "name": "dcardenasl/ci4-api-core-example",
    "description": "Working example of a REST API built with ci4-api-core + ci4-api-scaffolding. Demonstrates a Catalog domain (Categories, Products) scaffolded in minutes with zero boilerplate.",
    "license": "MIT",
    "type": "project",
    "keywords": [
        "codeigniter4",
        "codeigniter",
        "ci4",
        "example",
        "demo",
        "reference",
        "rest-api",
        "api",
        "dto",
        "scaffolding",
        "crud",
        "domain-driven-design",
        "service-layer"
    ],
    "homepage": "https://github.com/dcardenasl/ci4-api-core-example",
    "support": {
        "issues": "https://github.com/dcardenasl/ci4-api-core-example/issues",
        "source": "https://github.com/dcardenasl/ci4-api-core-example"
    },
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.7",
        "dcardenasl/ci4-api-core": "^1.0"
    },
    "require-dev": {
        "dcardenasl/ci4-api-scaffolding": "^0.7.5",
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}